# Copy to .env and fill locally. Never commit .env.
# File-based override: place a file named like the variable inside ./secrets/ (see settings docstring).

APP_ENV=development
LOG_LEVEL=INFO

# dev_session: IANA TZ for automation_quiet_hours (config/base.yaml). Headless on sensitive sites: GHOST_ALLOW_HEADLESS_SENSITIVE=1
# GHOST_AUTOMATION_TZ=Europe/Berlin
# GHOST_ALLOW_HEADLESS_SENSITIVE=1
#
# dev_session: each site_id is gated separately — no credentials → that site skipped (no Page). Unwired adapters
# are skipped until listed in dev_session._DEV_SESSION_READY_SITE_IDS. Parallel sites run independently.
# GHOST_DEV_ALLOW_UNREADY_SITES=1  # allow site_ids not yet marked ready (experiments only)

# Upwork stealth sortie: feed → operator → Messages → pending → drive_feed → return main → hibernate on current page (default).
# Set GHOST_UPWORK_STEALTH_GOTO_BLANK=1 to restore about:blank between sorties.
# GHOST_UPWORK_STEALTH_CYCLE=0  # legacy non-stealth pacing
#
# Operator queue (Telegram → Redis): default lists ghost:op:commands (+ :high); legacy ghost:operator:commands still drained.
# Optional overrides: GHOST_OPERATOR_COMMANDS_KEY, GHOST_OPERATOR_COMMANDS_HIGH_KEY, GHOST_OPERATOR_COMMANDS_LEGACY_KEY
# Messages task lists (future): ghost:msg:tasks (+ :high); GHOST_MESSAGE_TASKS_KEY, GHOST_MESSAGE_TASKS_HIGH_KEY
# GHOST_MESSAGES_AUDIT_DB=/path/to/chats_audit.sqlite  # default data/messages/chats_audit.sqlite
#
# --- Find-work Load More (stealth drive_feed) — см. ghost_engine.browser.feed_policy ---
# Быстрый путь: меньше human_click / пауз перед Load More (по умолчанию включён). Выключить: 0
# GHOST_FEED_STEALTH_FAST=1
# Макс. кликов Load More за одну сортку (default 15).
# GHOST_FEED_STEALTH_MAX_LOAD_MORE=15
# После каждого Load More: сколько раз PageDown+End к низу ленты (виртуализация карточек).
# GHOST_FEED_AFTER_LOAD_SCROLL_ROUNDS=8
# Если новых job id нет — доп. проходы скролла+пересъёма DOM (default 4).
# GHOST_FEED_EMPTY_FRESH_RETRIES=4
# Стоп ленты: столько подряд раундов с нулём новых id после дожима (default 2, min 2).
# GHOST_FEED_DUPLICATE_LOAD_STREAK_NEED=2
# Временной стоп: все вакансии в fresh имеют posted_at из GraphQL и каждая старше N дней (0 = выкл.).
# GHOST_FEED_MAX_POSTED_AGE_DAYS=0
# TTL множества ghost:feed:seen:<site>:<profile> в Redis (секунды). Нужен REDIS_URL для persist / redis_seen_wall.
# GHOST_FEED_SEEN_TTL_SEC=604800
# После пустого fresh: стоп, если доля видимых id уже в ghost:feed:seen:* >= порога (0 = выкл.; например 0.95).
# GHOST_FEED_REDIS_SEEN_WALL_MIN_RATIO=0
# Повторы клика Load More при сбое + бэкофф (мс).
# GHOST_FEED_LOAD_MORE_CLICK_RETRIES=2
# GHOST_FEED_LOAD_MORE_RETRY_MS_MIN=800
# GHOST_FEED_LOAD_MORE_RETRY_MS_MAX=2400
# Пауза между успешными раундами Load More (секунды): полный humanize 10–15; при GHOST_FEED_STEALTH_FAST — 4–7 (GHOST_FEED_INTER_FAST_*).
# GHOST_FEED_INTER_LOAD_MORE_SEC_MIN=10
# GHOST_FEED_INTER_LOAD_MORE_SEC_MAX=15
# GHOST_FEED_INTER_FAST_SEC_MIN=4
# GHOST_FEED_INTER_FAST_SEC_MAX=7
# Отключить паузу между раундами: GHOST_FEED_INTER_LOAD_MORE_DISABLE=1
# Отключить «залипание» и автосейв плиток по GRI: GHOST_FEED_LINGER_DISABLE=1
#
# Ops AI diagnosis: queue → Ollama текст → (если есть скрин) Ollama vision → Gemini только текст (без картинок) → ops.errors; полный провал → ops.system менеджеру.
# GHOST_OPS_AI_DIAG_ENABLED=1
# GHOST_OPS_AI_DIAG_USE_QUEUE=1
# GHOST_OPS_AI_DIAG_QUEUE_KEY=ghost:ops_ai_diag:queue
# Inline mode (no Redis queue): GHOST_OPS_AI_DIAG_USE_QUEUE=0
# Rate limit only for inline path; queued jobs notify per item.
# GHOST_OPS_AI_DIAG_MIN_SEC=120
# Viewport PNG только для локального Ollama vision; в Gemini не уходит (max raw bytes before base64).
# GHOST_OPS_AI_DIAG_IMAGE=1
# GHOST_OPS_AI_DIAG_IMAGE_MAX_BYTES=750000
# Max JSON payload per Redis message (image dropped if exceeded).
# GHOST_OPS_AI_DIAG_MAX_PAYLOAD_BYTES=1800000
# Start BLPOP worker at dev_session boot (still auto-starts on first enqueue).
# GHOST_OPS_AI_DIAG_WORKER_AUTOSTART=1
# Telegram ops.system alerts (separate from errors): backlog / slow jobs / crashes.
# GHOST_OPS_AI_QUEUE_DEPTH_ALERT=5
# GHOST_OPS_AI_QUEUE_WAIT_ALERT_SEC=120
# GHOST_OPS_AI_JOB_SLOW_SEC=180
# GHOST_OPS_AI_QUEUE_SYSTEM_ALERT_COOLDOWN_SEC=300
# Если все этапы LLM провалились — сводка в ops.system для менеджера (отдельный cooldown).
# GHOST_OPS_AI_MANAGER_ALERT_ENABLED=1
# GHOST_OPS_AI_MANAGER_ALERT_MIN_SEC=300
#
# Legacy --feed-loop (run_upwork_feed_load_more_loop): GHOST_FEED_MAX_LOAD_MORE, GHOST_FEED_OVERLAP_THRESHOLD, GHOST_FEED_OVERLAP_STREAK_BEFORE_STOP
# GHOST_FEED_MAX_LOAD_MORE=50
# GHOST_FEED_OVERLAP_THRESHOLD=0.4
# GHOST_FEED_OVERLAP_STREAK_BEFORE_STOP=1
# Hibernate between sorties (seconds, random uniform).
# GHOST_STEALTH_SLEEP_MIN_SEC=600
# GHOST_STEALTH_SLEEP_MAX_SEC=1800
# During hibernate, poll Redis / local queues this often (seconds) to wake early for pending_dom / Apply / pending_jobs_to_read.
# GHOST_STEALTH_HIBERNATE_POLL_SEC=4

# --- API / integrations (optional until you use them) ---
# Never commit real tokens. If leaked, /revoke in @BotFather and set a new token here or in secrets/TELEGRAM_BOT_TOKEN.
TELEGRAM_BOT_TOKEN=
# Primary operator chat id (@userinfobot). Merged with TELEGRAM_OPERATOR_CHAT_IDS.
TELEGRAM_CHAT_ID=
# Comma-separated chat/user IDs allowed for /start and job card callbacks.
# Job cards (GHOST Main), optional ChatClient, optional «Операции» if the bot handles commands there; add your user id for DM /start.
# Outbound ops alerts use ops.* in telegram_routing.yaml — they do not require listing here unless you need incoming handlers in that chat.
# Per-site destinations: config/telegram_routing.yaml (copy from telegram_routing.example.yaml).
TELEGRAM_OPERATOR_CHAT_IDS=
# Мин. секунд между алертами в ops.errors при падении всего scoring-графа (0 = каждый раз). См. job.scoring_graph_failed.
# GHOST_SCORING_GRAPH_ERROR_TELEGRAM_COOLDOWN_SEC=120

# Process mode: idle (default) | telegram-bot
# GHOST_ENGINE_MODE=telegram-bot

# Skip Redis notify enqueue from producers (browser / scoring_node).
# DISABLE_JOB_NOTIFY=1

# Telegram worker: post startup line to ops.topics.system (default on). Set 0 to disable.
# GHOST_WORKER_SYSTEM_STARTUP_NOTIFY=0
# Mirror failed job-card Telegram sends to ops.topics.errors (default on). Set 0 to disable.
# GHOST_WORKER_SEND_FAIL_TELEGRAM=0
# After `python -m ghost_engine.main health`, also send result to ops.topics.system (default off).
# GHOST_HEALTH_NOTIFY_SYSTEM=1
OPENAI_API_KEY=
GEMINI_API_KEY=
CLAUDE_API_KEY=

# Required for docker compose (postgres + redis services). Host apps read DATABASE_URL / REDIS_URL below.
POSTGRES_PASSWORD=change_me_generate_strong_hex
REDIS_PASSWORD=change_me_generate_strong_hex
# Host machine (ports published from compose): include passwords in URLs.
DATABASE_URL=postgresql+asyncpg://ghost:change_me_generate_strong_hex@localhost:5432/ghost_engine
REDIS_URL=redis://:change_me_generate_strong_hex@localhost:6379/0
OLLAMA_HOST=http://localhost:11434
# Ollama model tag for safety judges, L2 gray zone, emergency repair, parsing diagnostics (default: llama3.2-vision).
# GHOST_OLLAMA_MODEL=llama3.2-vision

BRIGHTDATA_PROXY_URL=
OXYLABS_USERNAME=
OXYLABS_PASSWORD=

2CAPTCHA_KEY=
CAMOUFOX_LICENSE=

# Captcha handling in dev_session (BaseSiteAdapter.check_for_captcha): manual wait then Telegram photo + optional block.
# GHOST_CAPTCHA_MANUAL_WAIT_SEC=45
# GHOST_CAPTCHA_POLL_INTERVAL_SEC=2.5
# GHOST_CAPTCHA_BLOCK_SEC=3600
# GHOST_CAPTCHA_BLOCK_ON_ALERT=1
# GHOST_CAPTCHA_ALERT_GREETING=Operator

# --- Site logins (personal accounts; keep only on your machine) ---
# Used by resolve_site_credentials("upwork") — password is SecretStr, do not print it.
# Google OAuth (no Upwork password): set UPWORK_EMAIL to your account email + persist session in profiles/<profile>,
# then GHOST_DEV_OAUTH_SESSION_UPWORK=1 (password field unused; do not autofill from SecretStr).
UPWORK_EMAIL=
UPWORK_PASSWORD=
# GHOST_DEV_OAUTH_SESSION_UPWORK=1
# After Log in on Upwork, auto-click Google account tile matching UPWORK_EMAIL (dev only). Set 0 to disable.
# GHOST_DEV_GOOGLE_OAUTH_ASSIST=0
# GHOST_DEV_GOOGLE_OAUTH_ASSIST_HUMANIZE=1  # optional: use human_click (micro-moves) on Google account tile; default off
# GHOST_DEV_FORCE_LOGIN=1  # dev_session: always run login/SSO probe even if logged-in shell looks visible
# GHOST_PIN_PROFILE_FINGERPRINT=0  # Camoufox: new random fingerprint each launch (default: pin on, see config/browser.yaml)
