{
  "extends": [
    "next"
  ],
  "rules": {
    // React rules
    "react/no-unescaped-entities": "error",
    "react-hooks/exhaustive-deps": "warn",
    // Next.js rules
    "@next/next/no-img-element": "warn",
    // General rules
    "no-console": "warn",
    "prefer-const": "error",
    "no-var": "error",
    "no-unused-vars": "warn"
  }
}