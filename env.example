# PostHog
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Daily.co
DAILY_API_KEY=your_daily_api_key_here

# Other
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-side base URL (recommended for callbacks)
APP_URL=http://localhost:3000

# Payment feature flags
PAYMENTS_ENABLE_STRIPE=true
PAYMENTS_ENABLE_CRYPTOMUS=false
PAYMENTS_ENABLE_RU_PSP=false

# RU PSP (YooKassa/Robokassa) scaffold
# Select provider: yookassa | robokassa (leave empty if not used)
RU_PSP_PROVIDER=

# YooKassa (recommended fields)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=${APP_URL}/checkout/success
YOOKASSA_WEBHOOK_URL=${APP_URL}/api/ru-psp/yookassa/webhook

# Robokassa (recommended fields)
ROBOKASSA_MERCHANT_LOGIN=
ROBOKASSA_PASSWORD1=
ROBOKASSA_PASSWORD2=
ROBOKASSA_RETURN_URL=${APP_URL}/checkout/success
ROBOKASSA_CALLBACK_URL=${APP_URL}/api/ru-psp/robokassa/callback

# AmoCRM Integration
AMOCRM_DOMAIN=your-domain.amocrm.ru
AMOCRM_CLIENT_ID=your_client_id
AMOCRM_CLIENT_SECRET=your_client_secret
AMOCRM_REDIRECT_URI=http://localhost:3000/api/auth/amocrm/callback
AMOCRM_ACCESS_TOKEN=your_access_token
AMOCRM_REFRESH_TOKEN=your_refresh_token

# Notifications (general)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
WEBHOOK_URL=your_webhook_url

# Issues-specific notifications (separate channel)
# Set NOTIFY_ISSUES_VIA_TELEGRAM=true to enable, otherwise disabled.
# If ISSUE_TELEGRAM_* are missing and ISSUE_TELEGRAM_FALLBACK_TO_GENERAL=true,
# falls back to TELEGRAM_BOT_TOKEN/TELEGRAM_CHAT_ID.
NOTIFY_ISSUES_VIA_TELEGRAM=false
ISSUE_TELEGRAM_BOT_TOKEN=your_issue_bot_token
ISSUE_TELEGRAM_CHAT_ID=your_issue_chat_id
ISSUE_TELEGRAM_FALLBACK_TO_GENERAL=false
# Optional: post into a specific topic (forum) inside a supergroup
ISSUE_TELEGRAM_THREAD_ID=

# EnergyLogic Support Bot - для уведомлений покупателей
USER_TELEGRAM_BOT_TOKEN=8289281549:AAHnCv4FRz62TBJN-wjPdt_kZ6T3tBj-sgY
USER_TELEGRAM_BOT_USERNAME=EnergyLogic_Support_bot
USER_TELEGRAM_WEBHOOK_URL=https://yourdomain.com/api/telegram/user-webhook
USER_TELEGRAM_WEBHOOK_SECRET=your_webhook_secret

# Email (Resend/SendGrid/SES)
RESEND_API_KEY=your_resend_api_key
NOTIFY_SENDER_EMAIL=noreply@yourdomain.com

# Enhanced Callback System
CALLBACK_SLA_FIRST_RESPONSE_HOURS=4
CALLBACK_SLA_RESOLUTION_HOURS=24
CALLBACK_AUTO_ASSIGN_ENABLED=true
CALLBACK_REMINDER_HOURS=2

# Google OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
