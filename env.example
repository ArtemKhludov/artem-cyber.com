# Site Configuration
NEXT_PUBLIC_SITE_URL=https://energylogic-ai.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console Verification
NEXT_PUBLIC_GOOGLE_VERIFICATION=your-verification-code

# Yandex Webmaster Verification (optional)
NEXT_PUBLIC_YANDEX_VERIFICATION=your-verification-code

# Google OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Cryptomus
CRYPTOMUS_MERCHANT_ID=your-cryptomus-merchant-id
CRYPTOMUS_API_KEY=your-cryptomus-api-key

# Email (Resend)
RESEND_API_KEY=your-resend-api-key
NOTIFY_SENDER_EMAIL=no-reply@energylogic-ai.com
NOTIFY_SENDER_NAME=EnergyLogic AI

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=your-telegram-webhook-secret

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Daily.co
NEXT_PUBLIC_DAILY_API_KEY=your-daily-api-key
DAILY_API_KEY=your-daily-api-key

# JWT Secrets for Mobile App Authentication
# Generate secure random strings (min 32 characters)
# Example: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars

# CORS Origins (comma-separated)
NEXT_PUBLIC_ALLOWED_ORIGINS=https://energylogic-ai.com,https://app.energylogic-ai.com

# Mobile App IDs (when ready)
NEXT_PUBLIC_MOBILE_IOS_BUNDLE_ID=com.energylogic.app
NEXT_PUBLIC_MOBILE_ANDROID_PACKAGE=com.energylogic.app

# Other
NODE_ENV=production
